# ╔═══════════════════════════════════════════════════════════════════════════════╗
# ║              DOTE 2.0 — Production Environment Variables                    ║
# ║   Copy this file to .env and fill in real values before deploying.          ║
# ║   NEVER commit .env to git. Only .env.example should be tracked.            ║
# ╚═══════════════════════════════════════════════════════════════════════════════╝

# ─── Application ──────────────────────────────────────────────────────────────
APP_PORT=80
FRONTEND_URL=http://localhost

# ─── MySQL Database ───────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=CHANGE_ME_root_password_2026
DB_NAME=admission_dote
DB_USER=dote_user
DB_PASS=CHANGE_ME_strong_password
DB_POOL_LIMIT=20

# ─── JWT Authentication ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_a_64_char_random_hex_secret
JWT_EXPIRE=24h
COOKIE_EXPIRE=1

# ─── CORS (comma-separated allowed origins, leave empty for same-origin) ─────
# Example: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=

# ─── Email / SMTP (optional — without these, password resets only log to console)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your.email@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# MAIL_FROM=DOTE Admission Portal <your.email@gmail.com>
# SMTP_TLS_REJECT_UNAUTHORIZED=true
