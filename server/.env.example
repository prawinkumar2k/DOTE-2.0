# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=admission_dote
DB_USER=root
DB_PASS=yourpassword
DB_POOL_LIMIT=20

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRE=24h

# ─── Cookie ───────────────────────────────────────────────────────────────────
COOKIE_EXPIRE=1

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated origins. Leave empty for same-origin (production behind Nginx).
ALLOWED_ORIGINS=

# ─── Frontend URL (for password-reset emails) ────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Email / SMTP (optional) ──────────────────────────────────────────────────
# Without these, password-reset links will only be logged to console.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your.email@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# MAIL_FROM=DOTE Admission Portal <your.email@gmail.com>
# SMTP_TLS_REJECT_UNAUTHORIZED=true
